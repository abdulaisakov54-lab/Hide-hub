local antiCheatBypass = {
    active = false
}
local function bypassAntiCheat()
    if antiCheatBypass.active then
        humanoid.WalkSpeed = 16
        humanoid.JumpPower = 50
        for _, v in pairs(ReplicatedStorage:GetDescendants()) do
            if v:IsA("RemoteEvent") and (v.Name:find("AntiCheat") or v.Name:find("Ban")) then
                v:Destroy()
            end
        end
        -- Скрываем аномалии движения
        if hrp then
            hrp:SetAttribute("RealSpeed", hrp.Velocity.Magnitude)
        end
    end
end

