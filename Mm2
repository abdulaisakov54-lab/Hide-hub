-- Функция создания кнопок с иконками (как на скринах)
local function createHubButton(text, icon, color, callback, y)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -20, 0, 35)
    btn.Position = UDim2.new(0, 10, 0, y or 0)
    btn.Text = icon .. "  " .. text
    btn.TextColor3 = Color3.fromRGB(220, 220, 255)
    btn.BackgroundColor3 = color or Color3.fromRGB(30, 30, 50)
    btn.BorderSizePixel = 1
    btn.BorderColor3 = Color3.fromRGB(60, 60, 100)
    btn.TextSize = 14
    btn.Font = Enum.Font.GothamMedium
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.Parent = buttonContainer
    btn.MouseButton1Click:Connect(callback)
    return btn
end

