-- ===== СОХРАНЕНИЕ КОНФИГА =====
local configKey = "RyzenMM2_Config"
local function saveConfig()
    local data = HttpService:JSONEncode(settings)
    if syn and syn.crypt then
        syn.crypt.save(configKey, data)
    else
        -- Альтернативное сохранение (для большинства executors)
        if writefile then
            writefile("RyzenMM2_Config.txt", data)
        end
    end
    print("✅ Конфиг сохранён!")
end

local function loadConfig()
    local data = nil
    if syn and syn.crypt then
        data = syn.crypt.load(configKey)
    elseif readfile then
        data = readfile("RyzenMM2_Config.txt")
    end
    if data then
        local loaded = HttpService:JSONDecode(data)
        for k, v in pairs(loaded) do
            settings[k] = v
        end
        print("✅ Конфиг загружен!")
        return true
    end
    return false
end

