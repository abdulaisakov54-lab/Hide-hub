-- ===== ФУНКЦИИ =====
-- ESP (упрощённый)
local espObjects = {}

function startESP()
    for _, plr in pairs(game.Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local hl = Instance.new("Highlight")
            hl.Adornee = plr.Character
            hl.FillColor = Color3.fromRGB(0, 200, 255)
            hl.FillTransparency = 0.4
            hl.Parent = plr.Character
            table.insert(espObjects, hl)
        end
    end
end

function stopESP()
    for _, obj in pairs(espObjects) do
        obj:Destroy()
    end
    espObjects = {}
end

-- Flick (быстрый поворот)
function startFlick()
    -- Имитация быстрого поворота
    game:GetService("RunService").RenderStepped:Connect(function()
        if settings.flickEnabled then
            local target = nil
            for _, plr in pairs(game.Players:GetPlayers()) do
                if plr ~= player and plr.Character then
                    target = plr.Character:FindFirstChild("Head")
                    if target then break end
                end
            end
            if target then
                cam.CFrame = CFrame.new(cam.CFrame.Position, target.Position)
            end
        end
    end)
end

function stopFlick() end

-- Grab Gun
function startGrabGun()
    local tool = char:FindFirstChildOfClass("Tool")
    if tool then
        tool:SetAttribute("Grab", true)
    end
end

function stopGrabGun() end

-- Speed Glitch
local speedConn = nil

function startSpeedGlitch()
    speedConn = RunService.RenderStepped:Connect(function()
        if settings.speedGlitchEnabled and hrp then
            local moveDir = humanoid.MoveDirection
            if moveDir.Magnitude > 0 then
                hrp.Velocity = moveDir * 70
            end
        end
    end)
end

function stopSpeedGlitch()
    if speedConn then
        speedConn:Disconnect()
        speedConn = nil
    end
end

-- Gold Bomb (визуальный эффект)
function startGoldBomb()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Part") and v.Name:find("Bomb") then
            v.Material = Enum.Material.Neon
            v.Color = Color3.fromRGB(255, 200, 0)
        end
    end
end

function stopGoldBomb() end

-- Normal Bomb
function startNormalBomb()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Part") and v.Name:find("Bomb") then
            v.Material = Enum.Material.SmoothPlastic
            v.Color = Color3.fromRGB(200, 100, 50)
        end
    end
end

function stopNormalBomb() end

-- Shoot/Throw (автоматический выстрел)
function startShootThrow()
    game:GetService("UserInputService").InputBegan:Connect(function(input)
        if settings.showShootThrow and input.UserInputType == Enum.UserInputType.MouseButton1 then
            local tool = char:FindFirstChildOfClass("Tool")
            if tool then
                tool:Activate()
            end
        end
    end)
end

function stopShootThrow() end

