-- ===== ESP =====
local espObjects = {}
local espConnections = {}

function startESP()
    local function getRole(plr)
        if plr.Character and plr.Character:FindFirstChild("Head") then
            local head = plr.Character.Head
            for _, obj in pairs(head:GetChildren()) do
                if obj:IsA("BillboardGui") and obj.Name == "Role" then
                    return obj.Text
                end
            end
        end
        return "Innocent"
    end
    
    local function addESP(plr)
        if plr == player or not plr.Character then return end
        local highlight = Instance.new("Highlight")
        highlight.Adornee = plr.Character
        local role = getRole(plr)
        highlight.FillColor = settings.roleESP[role:lower()] or Color3.fromRGB(0,255,0)
        highlight.FillTransparency = 0.3
        highlight.OutlineColor = Color3.fromRGB(255,255,255)
        highlight.OutlineTransparency = 0.3
        highlight.Parent = plr.Character
        table.insert(espObjects, highlight)
    end
    
    for _, plr in pairs(game.Players:GetPlayers()) do
        addESP(plr)
    end
    
    espConnections[1] = game.Players.PlayerAdded:Connect(function(plr)
        plr.CharacterAdded:Connect(function()
            wait(0.3)
            if settings.espEnabled then addESP(plr) end
        end)
    end)
end

function stopESP()
    for _, obj in pairs(espObjects) do
        if obj then obj:Destroy() end
    end
    espObjects = {}
    for _, conn in pairs(espConnections) do
        if conn then conn:Disconnect() end
    end
    espConnections = {}
end

-- ===== WALLHACK =====
local wallhackObjects = {}

function startWallhack()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and v.Material ~= Enum.Material.Neon then
            local origTrans = v.Transparency
            v.Transparency = 0.7
            table.insert(wallhackObjects, {obj = v, trans = origTrans})
        end
    end
end

function stopWallhack()
    for _, data in pairs(wallhackObjects) do
        if data.obj then
            data.obj.Transparency = data.trans
        end
    end
    wallhackObjects = {}
end

-- ===== AIMBOT =====
local aimConnection = nil

function startAimbot()
    aimConnection = RunService.RenderStepped:Connect(function()
        if not settings.aimEnabled then return end
        
        local target = nil
        local minDist = 500
        
        local playerRole = "Innocent"
        if char:FindFirstChild("Head") then
            for _, obj in pairs(char.Head:GetChildren()) do
                if obj:IsA("BillboardGui") and obj.Name == "Role" then
                    playerRole = obj.Text
                end
            end
        end
        
        for _, plr in pairs(game.Players:GetPlayers()) do
            if plr ~= player and plr.Character and plr.Character:FindFirstChild("Head") then
                local head = plr.Character.Head
                local dist = (head.Position - hrp.Position).Magnitude
                if dist > 200 then continue end
                
                local targetRole = "Innocent"
                for _, obj in pairs(head:GetChildren()) do
                    if obj:IsA("BillboardGui") and obj.Name == "Role" then
                        targetRole = obj.Text
                    end
                end
                
                if playerRole == "Murderer" and (targetRole == "Sheriff" or targetRole == "Innocent") and dist < minDist then
                    minDist = dist
                    target = head
                elseif playerRole == "Sheriff" and targetRole == "Murderer" and dist < minDist then
                    minDist = dist
                    target = head
                elseif playerRole == "Innocent" and targetRole == "Murderer" and dist < minDist then
                    minDist = dist
                    target = head
                end
            end
        end
        
        if target then
            cam.CFrame = CFrame.new(cam.CFrame.Position, target.Position)
        end
    end)
end

function stopAimbot()
    if aimConnection then
        aimConnection:Disconnect()
        aimConnection = nil
    end
end

