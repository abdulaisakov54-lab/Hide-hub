    if settings.walkSpeed and humanoid then
        humanoid.WalkSpeed = settings.walkSpeedValue
    end
    if settings.jumpPower and humanoid then
        humanoid.JumpPower = settings.jumpPowerValue
    end
end)

-- Auto Pickup Gun
RunService.RenderStepped:Connect(function()
    if settings.autoPickupGun then
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("Tool") and (obj.Name:lower():find("gun") or obj.Name:lower():find("pistol")) then
                if obj.Parent ~= char and obj:FindFirstChild("Handle") then
                    if (hrp.Position - obj.Handle.Position).Magnitude < 15 then
                        local tool = obj
                        tool.Handle:Destroy()
                        tool.Parent = char
                        break
                    end
                end
            end
        end
    end
end)

-- Kill Aura
RunService.RenderStepped:Connect(function()
    if settings.killAura and settings.role == "Murderer" then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= player and plr.Character and plr.Character:FindFirstChild("Head") then
                local role = getPlayerRole(plr)
                if settings.killAuraMode == "All" then
                    if (hrp.Position - plr.Character.Head.Position).Magnitude < 15 then
                        plr.Character.Humanoid.Health = 0
                    end
                elseif settings.killAuraMode == "Sheriff" and role == "Sheriff" then
                    if (hrp.Position - plr.Character.Head.Position).Magnitude < 15 then
                        plr.Character.Humanoid.Health = 0
                    end
                end
            end
        end
    end
end)

-- Auto Fling Sheriff
RunService.RenderStepped:Connect(function()
    if settings.autoFlingSheriff and settings.role == "Murderer" then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= player and plr.Character and plr.Character:FindFirstChild("Head") then
                local role = getPlayerRole(plr)
                if role == "Sheriff" then
                    local dist = (hrp.Position - plr.Character.Head.Position).Magnitude
                    if dist < 20 then
                        local bv = Instance.new("BodyVelocity")
                        bv.MaxForce = Vector3.new(1, 1, 1) * 100000
                        bv.Velocity = (plr.Character.Head.Position - hrp.Position).Unit * 200
                        bv.Parent = plr.Character.HumanoidRootPart
                        task.wait(0.1)
                        bv:Destroy()
                    end
                end
            end
        end
    end
end)

-- Touch Fling
if settings.touchFling then
    char.Touched:Connect(function(part)
        if part.Parent and part.Parent:FindFirstChild("Humanoid") then
            local target = part.Parent
            if target ~= char then
                local bv = Instance.new("BodyVelocity")
                bv.MaxForce = Vector3.new(1, 1, 1) * 100000
                bv.Velocity = (target.Head.Position - hrp.Position).Unit * settings.flingPower
                bv.Parent = target.HumanoidRootPart
                task.wait(0.1)
                bv:Destroy()
            end
        end
    end)
end

