function updateRole()
    if char and char:FindFirstChild("Head") then
        local head = char.Head
        for _, obj in pairs(head:GetChildren()) do
            if obj:IsA("BillboardGui") and obj.Name == "Role" then
                settings.role = obj.Text
                roleLabel.Text = "Роль: " .. settings.role
                roleLabel.TextColor3 = settings.role == "Murderer" and Color3.fromRGB(255, 0, 0) or 
                                       settings.role == "Sheriff" and Color3.fromRGB(0, 100, 255) or 
                                       Color3.fromRGB(0, 255, 0)
                
                -- Обновляем кнопку оружия
                if settings.role == "Murderer" then
                    weaponBtn.Text = "🔪 Кинжал (Убийца)"
                    weaponBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
                    settings.weapon = "Knife"
                elseif settings.role == "Sheriff" then
                    weaponBtn.Text = "🔫 Пистолет (Шериф)"
                    weaponBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 150)
                    settings.weapon = "Gun"
                else
                    weaponBtn.Text = "❌ Нет оружия"
                    weaponBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
                    settings.weapon = nil
                end
                return
            end
        end
    end
    roleLabel.Text = "Роль: Ожидание..."
    roleLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
end

